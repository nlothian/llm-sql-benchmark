---
import "../styles/distill-theme.css";
import "rehype-github-alerts/styling/css/index.css";

type TocHeading = {
  depth: number;
  slug: string;
  text: string;
};

type NavLink = {
  label: string;
  href: string;
  icon?: string;
};

type Frontmatter = {
  title?: string;
  description?: string;
  ogImage?: string;
  ogTitle?: string;
  ogDescription?: string;
  kicker?: string;
  authors?: string[];
  affiliations?: string[];
  published?: string;
  doi?: string;
  toc?: boolean;
  showByline?: boolean;
  brand?: string;
  navLinks?: NavLink[];
  footerText?: string;
};

const { frontmatter = {}, headings = [] } = Astro.props as {
  frontmatter?: Frontmatter;
  headings?: TocHeading[];
};

const {
  title = "Untitled",
  description,
  ogImage,
  ogTitle,
  ogDescription,
  kicker,
  authors = [],
  affiliations = [],
  published,
  doi,
  toc = true,
  showByline = true,
  brand = "LLM SQL Benchmark",
  navLinks = [],
  footerText = "Built for reproducible SQL benchmark reporting."
} = frontmatter;

const tocHeadings = toc
  ? headings.filter((heading) => {
      const hasText = Boolean(heading.text?.trim());
      const hasSlug = Boolean(heading.slug?.trim());
      return hasText && hasSlug && heading.depth >= 2 && heading.depth <= 3;
    })
  : [];

const hasToc = tocHeadings.length > 0;
  const hasByline =
  showByline &&
  (authors.length > 0 ||
    affiliations.length > 0 ||
  Boolean(published) ||
  Boolean(doi));

const pageDescription = description ?? "";
const socialImage = (ogImage ?? "").trim();
const socialTitle = (ogTitle ?? title ?? "").trim();
const socialDescription = (ogDescription ?? pageDescription ?? "").trim();
const hasSocialImage = socialImage.length > 0;
const twitterCard = hasSocialImage ? "summary_large_image" : "summary";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={pageDescription} />
    {socialTitle && <meta property="og:title" content={socialTitle} />}
    {socialDescription && <meta property="og:description" content={socialDescription} />}
    {hasSocialImage && <meta property="og:image" content={socialImage} />}
    {socialTitle && <meta name="twitter:title" content={socialTitle} />}
    {socialDescription && <meta name="twitter:description" content={socialDescription} />}
    {hasSocialImage && <meta name="twitter:image" content={socialImage} />}
    <meta name="twitter:card" content={twitterCard} />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />

    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-HS65P8FKQ4"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());

      gtag('config', 'G-HS65P8FKQ4');
    </script>


  </head>
  <body class:list={[hasToc ? "has-toc" : "no-toc"]}>
    <header class="distill-masthead">
      <div class="distill-masthead-inner">
        <a class="distill-brand" href="/">{brand}</a>
        {navLinks.length > 0 && (
          <nav class="distill-masthead-nav" aria-label="Site">
            {navLinks.map((link) => (
              <a href={link.href} title={link.label}>
                {link.icon === "github" && (
                  <svg class="nav-icon" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg>
                )}
                {link.icon === "x" && (
                  <svg class="nav-icon" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
                )}
                {link.icon === "bluesky" && (
                  <svg class="nav-icon" viewBox="0 0 24 24" fill="currentColor"><path d="M12 10.8c-1.087-2.114-4.046-6.053-6.798-7.995C2.566.944 1.561 1.266.902 1.565.139 1.908 0 3.08 0 3.768c0 .69.378 5.65.624 6.479.785 2.627 3.6 3.496 6.158 3.16-.038.01-.075.023-.113.035-3.012.97-6.688 3.043-4.183 7.378 2.76 4.064 4.97.295 6.514-2.66.402-.77.701-1.582.898-2.16.197.578.496 1.39.898 2.16 1.544 2.955 3.754 6.724 6.514 2.66 2.505-4.336-1.171-6.409-4.183-7.378-.038-.012-.075-.024-.113-.035 2.558.336 5.373-.533 6.158-3.16.246-.828.624-5.788.624-6.479 0-.688-.139-1.86-.902-2.203-.659-.3-1.664-.62-4.3 1.24C16.046 4.748 13.087 8.687 12 10.8z"/></svg>
                )}
                {link.icon === "linkedin" && (
                  <svg class="nav-icon" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
                )}
                <span class="nav-label">{link.label}</span>
              </a>
            ))}
          </nav>
        )}
      </div>
    </header>

    <main>
      <section class="distill-title">
        <div class="distill-title-inner">
          <div class="distill-title-copy">
            {kicker && <p class="distill-kicker">{kicker}</p>}
            <h1>{title}</h1>
            {description && <p class="distill-description">{description}</p>}
          </div>
        </div>
      </section>

      {hasByline && (
        <section class="distill-byline">
          <div class="distill-byline-inner">
            <div class="distill-byline-grid">
              {authors.length > 0 && (
                <div>
                  <h3>Authors</h3>
                  <p>{authors.join(", ")}</p>
                </div>
              )}

              {affiliations.length > 0 && (
                <div>
                  <h3>Affiliations</h3>
                  <p>{affiliations.join(", ")}</p>
                </div>
              )}

              {published && (
                <div>
                  <h3>Published</h3>
                  <p>{published}</p>
                </div>
              )}

              {doi && (
                <div>
                  <h3>DOI</h3>
                  <p>
                    <a href={`https://doi.org/${doi}`}>{doi}</a>
                  </p>
                </div>
              )}
            </div>
          </div>
        </section>
      )}

      <section class="distill-article">
        <div class:list={["distill-article-inner", hasToc ? "with-toc" : "without-toc"]}>
          {hasToc && (
            <aside class="distill-contents" aria-label="Contents">
              <nav>
                <h3>Contents</h3>
                <ol>
                  {tocHeadings.map((heading) => (
                    <li class={`depth-${heading.depth}`}>
                      <a data-toc-link href={`#${heading.slug}`}>{heading.text}</a>
                    </li>
                  ))}
                </ol>
              </nav>
            </aside>
          )}
          
          <article class="distill-content">
            <slot />
          </article>
        </div>
      </section>
    </main>

    <footer class="distill-footer">
      <div class="distill-footer-inner">
        <p>{footerText}</p>
      </div>
    </footer>

    {hasToc && (
      <script is:inline>
        (() => {
          const tocLinks = Array.from(
            document.querySelectorAll("a[data-toc-link]")
          );

          if (!tocLinks.length) {
            return;
          }

          const linkToId = (link) => {
            const href = link.getAttribute("href") || "";
            return decodeURIComponent(href.replace(/^#/, ""));
          };

          const headings = tocLinks
            .map((link) => document.getElementById(linkToId(link)))
            .filter((heading) => heading instanceof HTMLElement);

          if (!headings.length) {
            return;
          }

          const setActive = (activeId) => {
            for (const link of tocLinks) {
              const id = linkToId(link);
              link.classList.toggle("is-active", id === activeId);
            }
          };

          const refreshActiveFromScroll = () => {
            const pastHeadings = headings.filter(
              (heading) => heading.getBoundingClientRect().top <= 136
            );

            if (pastHeadings.length > 0) {
              setActive(pastHeadings[pastHeadings.length - 1].id);
              return;
            }

            setActive(headings[0].id);
          };

          const observer = new IntersectionObserver(
            () => {
              refreshActiveFromScroll();
            },
            {
              rootMargin: "-120px 0px -62% 0px",
              threshold: [0, 1]
            }
          );

          for (const heading of headings) {
            observer.observe(heading);
          }

          let scrollTicking = false;
          const onScroll = () => {
            if (scrollTicking) {
              return;
            }

            scrollTicking = true;
            requestAnimationFrame(() => {
              refreshActiveFromScroll();
              scrollTicking = false;
            });
          };

          window.addEventListener("scroll", onScroll, { passive: true });
          window.addEventListener("resize", onScroll);
          window.addEventListener("hashchange", refreshActiveFromScroll);
          for (const link of tocLinks) {
            link.addEventListener("click", () => {
              requestAnimationFrame(refreshActiveFromScroll);
            });
          }

          refreshActiveFromScroll();
        })();
      </script>
    )}

    <script>
      import "../scripts/mermaid-init";
    </script>
  </body>
</html>
