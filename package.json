{
  "name": "llm-sql-benchmark",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "bundle-benchmark": "node scripts/bundle-benchmark.mjs",
    "benchmark:cli": "npx tsx apps/cli/src/benchmark.ts",
    "benchmark:summary": "npx tsx apps/cli/src/create-benchmarks-summary.ts",
    "typecheck": "tsc -p tsconfig.json",
    "test": "npm run bundle-benchmark && vitest run",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "check": "npm run lint && npm run test && npm run typecheck"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "eslint": "^9.39.1",
    "globals": "^16.5.0",
    "tsx": "^4.20.6",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vitest": "^4.0.18"
  }
}
