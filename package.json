{
  "name": "llm-sql-benchmark",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*",
    "site"
  ],
  "scripts": {
    "bundle-benchmark": "node scripts/bundle-benchmark.mjs",
    "generate-answers": "node scripts/generate-answers.mjs",
    "prepare-site-data": "npx tsx scripts/prepare-site-data.ts",
    "rescore": "node scripts/rescore-benchmarks.mjs",
    "sync-logs": "npx tsx scripts/sync-logs.ts",
    "benchmark:cli": "npm run bundle-benchmark && npx tsx apps/cli/src/benchmark.ts",
    "site:dev": "npm run sync-logs && npm run generate-answers && npm run prepare-site-data && npm --workspace site run dev",
    "site:build": "npm run generate-answers && npm run prepare-site-data && npm --workspace site run build",
    "site:preview": "npm --workspace site run preview",
    "site:astro": "npm --workspace site run astro",
    "typecheck": "tsc -p tsconfig.json",
    "test": "npm run bundle-benchmark && vitest run",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "check": "npm run lint && npm run test && npm run typecheck"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "eslint": "^9.39.1",
    "globals": "^16.5.0",
    "tsx": "^4.20.6",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vitest": "^4.0.18",
    "wrangler": "^4.77.0"
  },
  "overrides": {
    "@vitejs/plugin-react": "~5.1.4"
  }
}
